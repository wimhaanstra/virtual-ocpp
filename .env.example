# The compose stack exposes the app on localhost:8797.

SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-me
# Optional. When set, chargers must connect with OCPP Basic Auth where username equals charger id.
# OCPP_BASIC_AUTH_PASSWORD=charger-password
# Optional. Overrides the charger URL shown on the dashboard, useful behind TLS/reverse proxies.
# OCPP_PUBLIC_URL=wss://ocpp.example.com/ocpp/:chargerId
# Optional Traefik override settings. VIRTUAL_OCPP_HOST should match OCPP_PUBLIC_URL's host.
# VIRTUAL_OCPP_HOST=ocpp.example.com
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERT_RESOLVER=letsencrypt
# TRAEFIK_NETWORK=traefik
# Number of hours to keep full redacted OCPP communication journal rows before automatic purge.
COMMUNICATION_LOG_RETENTION_HOURS=24
CHARGER_SILENT_AFTER_SECONDS=300
METER_GAP_THRESHOLD_WH=1000
