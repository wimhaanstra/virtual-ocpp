{
  "name": "virtual-ocpp",
  "version": "0.1.0-20260628",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:server": "npm run dev --workspace=@virtual-ocpp/server",
    "dev:web": "npm run dev --workspace=@virtual-ocpp/web",
    "dev:stop": "node scripts/stop-dev-processes.mjs",
    "simulator": "npm run simulator --workspace=@virtual-ocpp/server --",
    "smoke:simulator": "npm run simulator -- --smoke",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=@virtual-ocpp/server",
    "seed:demo": "npm run seed:demo --workspace=@virtual-ocpp/server --",
    "seed:sessions": "npm run seed:sessions --workspace=@virtual-ocpp/server --",
    "release:version": "node scripts/set-release-version.mjs",
    "docker:build": "npm run release:version && node scripts/docker-image.mjs build",
    "docker:build:amd64": "npm run release:version && node scripts/docker-image.mjs build:amd64",
    "docker:push": "npm run docker:publish",
    "docker:publish": "npm run release:version && node scripts/docker-image.mjs publish"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
